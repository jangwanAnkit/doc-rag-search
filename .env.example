# LLM Providers
CEREBRAS_API_KEY=your_cerebras_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Vector Backend (zvec = local, qdrant = cloud)
VECTOR_BACKEND=zvec
VECTOR_STORE_PATH=.vector_store
VECTOR_SCORE_THRESHOLD=0.25

# RAG Settings
RAG_COLLECTION_NAME=legal_casebase
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.80
RAG_HYBRID_SEARCH=false
RAG_SPARSE_MODEL=prithivida/Splade_PP_en_v1
RAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Reranking
RAG_ENABLE_RERANKING=true
RAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Qdrant (optional - for cloud backup)
QDRANT_URL=https://your-cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# API Settings
API_SECRET_KEY=your-secret-key-change-in-production
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
API_MAX_QUESTION_LENGTH=500
API_MAX_SOURCES=3
API_RATE_LIMIT_PER_IP=20/minute
API_MAX_CONCURRENT_REQUESTS=10
API_DEBUG=false

# Portfolio Info (for legal demo - customize)
PORTFOLIO_OWNER_NAME="Legal Assistant"
PORTFOLIO_OWNER_EMAIL=legal@example.com
PORTFOLIO_DOMAIN=localhost:8000
PORTFOLIO_TITLE="Legal Research Assistant"

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
